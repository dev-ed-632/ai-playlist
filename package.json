{
  "name": "zipdj",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3022",
    "import:zipdj": "tsx scripts/import-zipdj-csv.ts",
    "build": "next build",
    "start": "next start",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart zipdj",
    "pm2:stop": "pm2 stop zipdj",
    "pm2:logs": "pm2 logs zipdj",
    "lint": "eslint",
    "db:introspect": "drizzle-kit introspect && node scripts/fix-drizzle-after-introspect.mjs",
    "db:studio": "drizzle-kit studio",
    "db:docker:up": "docker compose up -d",
    "db:docker:down": "docker compose down -v",
    "db:docker:logs": "docker compose logs -f postgres",
    "db:apply-schema": "docker compose exec -T postgres psql -U postgres -d zipdj_ai -v ON_ERROR_STOP=1 < schema.sql"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.63",
    "@xenova/transformers": "^2.17.2",
    "ai": "^6.0.177",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "essentia.js": "^0.1.3",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.0",
    "openai": "^6.33.0",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
